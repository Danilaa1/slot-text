{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "baseUrl": "..",
    "paths": {
      "slot-text": ["./src/index.ts"],
      "slot-text/solid": ["./src/solid.ts"],
      "slot-text/svelte": ["./src/svelte.ts"]
    }
  },
  "include": ["env.d.ts", "solid.tsx", "../src"]
}
